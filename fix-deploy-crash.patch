+# Copy this file to .env and fill in real values for local development.
+# In production (Render), these are set as environment variables in the
+# dashboard / render.yaml instead — never commit a real .env file.
+
+# Database
+DATABASE_URL=postgresql+psycopg2://judge_user:judge_pass@localhost:5432/judge_db
+
+# Redis (used for the submission queue + auth rate-limit/lockout tracking)
+REDIS_URL=redis://localhost:6379
+
+# JWT auth — generate a real random value for this, e.g.:
+#   python3 -c "import secrets; print(secrets.token_hex(32))"
+SECRET_KEY=change-this-in-production
+ALGORITHM=HS256
+ACCESS_TOKEN_EXPIRE_MINUTES=180
+
+# Judge execution limits
+TIME_LIMIT_SECONDS=2
+MEMORY_LIMIT_MB=256
+
+# Google Sign-In (optional — leave blank to disable)
+GOOGLE_CLIENT_ID=
+
+# GitHub OAuth (optional — leave blank to disable)
+GITHUB_CLIENT_ID=
+GITHUB_CLIENT_SECRET=
+
+# Frontend/API URLs (used for CORS + OAuth redirect construction)
+FRONTEND_URL=http://localhost:5500
+API_URL=http://localhost:8000
+
+# AI Code Review (optional — leave blank to disable; get a free key at
+# https://aistudio.google.com/apikey)
+GEMINI_API_KEY=
